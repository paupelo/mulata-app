{
  "name": "mulata-app",
  "version": "1.0.0",
  "description": "PWA de gestión de la cuenta de resultados de la marca de moda Mulata (Panamá).",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev:server": "nodemon server/index.js",
    "dev:client": "npm --prefix client run dev",
    "dev": "concurrently -n server,client -c blue,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "install:client": "npm --prefix client install --include=dev",
    "build": "npm run install:client && npm --prefix client run build",
    "start": "node server/index.js",
    "backup": "node server/backup.js",
    "migrate": "node server/migrate.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4"
  }
}
