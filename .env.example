# ─────────────────────────────────────────────────────────────
# Variables de entorno de Mulata App
# Copia este archivo a .env y rellena los valores reales.
# ─────────────────────────────────────────────────────────────

# Cadena de conexión a PostgreSQL.
# En local puedes usar: postgresql://postgres:postgres@localhost:5432/mulata
# En Render se rellena automáticamente con la "Internal Database URL".
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mulata

# Secreto para firmar los JWT de sesión. Usa algo largo y aleatorio.
# Puedes generarlo con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria

# Credenciales de acceso a la app (login de Mere).
AUTH_USERNAME=mere
AUTH_PASSWORD=cambia-esta-contrasena

# Puerto del servidor (Render lo inyecta automáticamente).
PORT=3000

# Entorno: development | production
NODE_ENV=development
